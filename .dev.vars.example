# Copy to `.dev.vars` for `wrangler dev` / `bun test tests/smoke.test.ts`.
# `.dev.vars` is gitignored — never commit real secrets.

# Flip prod posture off so X-Dev-User works (Clerk unconfigured in local dev).
ENVIRONMENT=development

# Shared secret between dispatcher and VaultDO. Any string is fine in dev.
DO_INTERNAL_SECRET=dev-do-internal-secret-change-me

# Optional: add when you want to exercise the real flows locally.
# CLERK_SECRET_KEY=sk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
